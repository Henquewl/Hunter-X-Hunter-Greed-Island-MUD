# Compiled binaries
bin/*
!bin/.gitkeep
src/*.o
src/util/*.o

# Player save files (do not version, reset on each deploy)
lib/plrfiles/**/*.plr
lib/plrfiles/index
lib/plrobjs/**/*.objs

# Runtime logs and state
lib/etc/last
lib/etc/time
lib/etc/plrmail

# .claude folder (Claude Code memory) -- do NOT ignore
# !.claude/
